{
  "name": "artiste-meetup-backend",
  "version": "1.0.0",
  "description": "REST API backend for Artiste Meetup platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsc && tsc-alias",
    "vercel-build": "npm run build",
    "dev": "npx ts-node-dev -r dotenv/config -r tsconfig-paths/register --files src/server.ts",
    "seedData": "npx ts-node -r dotenv/config -r tsconfig-paths/register src/scripts/seed.ts",
    "seedAdmin": "npx ts-node -r dotenv/config -r tsconfig-paths/register src/scripts/seeding/super-admin.seeder.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "_moduleAliases": {
    "@": "src"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "mongoose": "^8.5.1",
    "ms": "^2.1.3",
    "nodemailer": "^8.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ms": "^0.7.34",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  }
}
